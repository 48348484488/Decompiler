<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:text="🔬 Lab — código executado (CDL)"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:textStyle="bold"
        android:fontFamily="monospace" />

    <TextView
        android:id="@+id/labSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:text=""
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:fontFamily="monospace" />

    <Spinner
        android:id="@+id/regionSpinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/disasmList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/surface" />

    <TextView
        android:id="@+id/editHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="6dp"
        android:text="Toque numa linha para editá-la"
        android:textColor="@color/mono_green"
        android:textSize="11sp"
        android:fontFamily="monospace" />

    <EditText
        android:id="@+id/editInstruction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:hint="ex: LDA #$05  ou  NOP"
        android:textColorHint="@color/text_secondary"
        android:textColor="@color/text_primary"
        android:fontFamily="monospace"
        android:maxLines="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp">

        <Button
            android:id="@+id/testButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="▶ Testar na ROM"
            android:textAllCaps="false"
            android:backgroundTint="@color/accent" />

        <Button
            android:id="@+id/revertButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="↩ Desfazer"
            android:textAllCaps="false"
            android:backgroundTint="@color/snes_purple" />

        <Button
            android:id="@+id/spritesButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="🎨 Sprites"
            android:textAllCaps="false"
            android:backgroundTint="@color/accent_dim" />
    </LinearLayout>

</LinearLayout>
