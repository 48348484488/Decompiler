<?xml version="1.0" encoding="utf-8"?>
<!-- Root is a plain vertical LinearLayout: video area gets whatever space
     is left (weight=1, height=0dp - the standard, battle-tested Android
     pattern for "fill remaining space"), controlsArea is a fixed 210dp
     strip below it. This replaces an earlier ConstraintLayout version
     where the video ImageView rendered at a small, near-native-pixel
     size despite 0dp/match-constraint sizing - switching to
     LinearLayout weights sidesteps whatever was going on there. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:keepScreenOn="true">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#000000">

        <ImageView
            android:id="@+id/videoView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter" />

        <TextView
            android:id="@+id/pcReadout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:background="#AA000000"
            android:fontFamily="monospace"
            android:textColor="@color/mono_green"
            android:textSize="11sp"
            android:padding="6dp"
            android:text="PC: --:----" />

        <TextView
            android:id="@+id/cdlReadout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:background="#AA000000"
            android:fontFamily="monospace"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:padding="6dp"
            android:text="CDL: 0%" />

    </FrameLayout>

    <!-- Control bar, 210dp fixed. Two horizontal bands, verified by hand
         so nothing overlaps:
           Row 1 (0-40dp):    L ... SELECT START ... R
           Row 2 (40-210dp):  D-pad (left half) | A/B/X/Y diamond (right half)
         Row 2's contents are anchored from row1Guideline downward
         (D-pad) or from the container bottom upward (diamond); both
         chains fit inside 210dp with margin to spare (checked below). -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/controlsArea"
        android:layout_width="match_parent"
        android:layout_height="210dp"
        android:background="@color/surface">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/row1Guide"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_begin="40dp" />

        <!-- Row 1 -->
        <Button
            android:id="@+id/btnL"
            android:layout_width="56dp"
            android:layout_height="34dp"
            android:text="L"
            android:textSize="12sp"
            android:backgroundTint="@color/accent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="4dp"
            android:layout_marginStart="20dp" />

        <Button
            android:id="@+id/btnR"
            android:layout_width="56dp"
            android:layout_height="34dp"
            android:text="R"
            android:textSize="12sp"
            android:backgroundTint="@color/accent"
            app:layout_constraintTop_toTopOf="@id/btnL"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="20dp" />

        <Button
            android:id="@+id/btnSelect"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:text="SELECT"
            android:textSize="9sp"
            android:backgroundTint="@color/bg_dark"
            android:textColor="@color/text_secondary"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            app:layout_constraintTop_toTopOf="@id/btnL"
            app:layout_constraintEnd_toStartOf="@id/btnStart"
            app:layout_constraintStart_toEndOf="@id/btnL" />

        <Button
            android:id="@+id/btnStart"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:text="START"
            android:textSize="9sp"
            android:backgroundTint="@color/bg_dark"
            android:textColor="@color/text_secondary"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            app:layout_constraintTop_toTopOf="@id/btnL"
            app:layout_constraintStart_toEndOf="@id/btnSelect"
            app:layout_constraintEnd_toStartOf="@id/btnR" />

        <!-- Row 2: D-pad. Needs up(44)+gap4+mid(44)+gap4+down(44)=140dp
             starting 8dp below row1Guide(40) -> bottom at 40+8+140=188,
             comfortably inside 210dp. -->
        <Button
            android:id="@+id/btnUp"
            android:layout_width="50dp"
            android:layout_height="44dp"
            android:text="▲"
            android:backgroundTint="@color/accent_dim"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/row1Guide"
            android:layout_marginStart="30dp"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnLeft"
            android:layout_width="50dp"
            android:layout_height="44dp"
            android:text="◀"
            android:backgroundTint="@color/accent_dim"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnUp"
            android:layout_marginStart="4dp"
            android:layout_marginTop="4dp" />

        <Button
            android:id="@+id/btnRight"
            android:layout_width="50dp"
            android:layout_height="44dp"
            android:text="▶"
            android:backgroundTint="@color/accent_dim"
            app:layout_constraintStart_toEndOf="@id/btnLeft"
            app:layout_constraintTop_toTopOf="@id/btnLeft"
            android:layout_marginStart="50dp" />

        <Button
            android:id="@+id/btnDown"
            android:layout_width="50dp"
            android:layout_height="44dp"
            android:text="▼"
            android:backgroundTint="@color/accent_dim"
            app:layout_constraintStart_toStartOf="@id/btnUp"
            app:layout_constraintTop_toBottomOf="@id/btnLeft"
            android:layout_marginTop="4dp" />

        <!-- Row 2: A/B/X/Y diamond, anchored bottom-up so the math is
             easy to verify: B(44)+gap6+[Y/A row](44)+gap6+X(44)=144dp,
             plus marginBottom 10 = 154dp, so X's top lands at
             210-154=56dp - well clear of row1 (ends at 40dp). -->
        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/diamondGuide"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_end="90dp" />

        <Button
            android:id="@+id/btnB"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="B"
            android:backgroundTint="@color/snes_purple"
            app:layout_constraintStart_toEndOf="@id/btnY"
            app:layout_constraintEnd_toStartOf="@id/btnA"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btnY"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="Y"
            android:backgroundTint="@color/snes_purple"
            app:layout_constraintEnd_toEndOf="@id/diamondGuide"
            app:layout_constraintBottom_toTopOf="@id/btnB"
            android:layout_marginEnd="6dp"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/btnA"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="A"
            android:backgroundTint="@color/snes_purple"
            app:layout_constraintStart_toStartOf="@id/diamondGuide"
            app:layout_constraintBottom_toTopOf="@id/btnB"
            android:layout_marginStart="6dp"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/btnX"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="X"
            android:backgroundTint="@color/snes_purple"
            app:layout_constraintStart_toEndOf="@id/btnY"
            app:layout_constraintEnd_toStartOf="@id/btnA"
            app:layout_constraintBottom_toTopOf="@id/btnY"
            android:layout_marginBottom="6dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</LinearLayout>
