<?xml version="1.0" encoding="utf-8"?>
<!-- Emulator screen modeled on standard mobile emulators (RetroArch / Snes9x
     EX+ style): the video fills the whole screen (letterboxed to aspect
     ratio, black bars on the sides in landscape), and the touch controls are
     OVERLAID on top of it - a D-pad cross on the left, A/B/X/Y round buttons
     on the right, L/R at the upper corners, Select/Start pills near the top.
     Everything is one big FrameLayout so controls float over the video. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:keepScreenOn="true">

    <ImageView
        android:id="@+id/videoView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="center" />

    <!-- Overlay readouts (kept from before, small and translucent) -->
    <TextView
        android:id="@+id/pcReadout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:background="#66000000"
        android:fontFamily="monospace"
        android:textColor="@color/mono_green"
        android:textSize="10sp"
        android:padding="4dp"
        android:text="PC: --:----" />

    <TextView
        android:id="@+id/cdlReadout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:background="#66000000"
        android:fontFamily="monospace"
        android:textColor="@color/text_secondary"
        android:textSize="9sp"
        android:padding="4dp"
        android:text="CDL 0%" />

    <!-- ===== LEFT SIDE ===== -->

    <!-- L shoulder, upper-left -->
    <Button
        android:id="@+id/btnL"
        android:layout_width="60dp"
        android:layout_height="40dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="16dp"
        android:layout_marginTop="44dp"
        android:background="@drawable/btn_pill"
        android:text="L"
        android:textColor="#DDFFFFFF"
        android:textSize="13sp" />

    <!-- Select pill, top -->
    <Button
        android:id="@+id/btnSelect"
        android:layout_width="wrap_content"
        android:layout_height="34dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="90dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/btn_pill"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:text="Select"
        android:textColor="#DDFFFFFF"
        android:textSize="10sp"
        android:textAllCaps="false" />

    <!-- D-pad cross, lower-left. Transparent ImageView shows the cross art;
         four invisible buttons on top handle the touch zones. -->
    <FrameLayout
        android:id="@+id/dpadFrame"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="24dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/dpad_cross"
            android:contentDescription="dpad" />

        <!-- Touch zones: up/down/left/right occupy the arms of the cross -->
        <View
            android:id="@+id/btnUp"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="top|center_horizontal" />

        <View
            android:id="@+id/btnDown"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="bottom|center_horizontal" />

        <View
            android:id="@+id/btnLeft"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="center_vertical|start" />

        <View
            android:id="@+id/btnRight"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="center_vertical|end" />
    </FrameLayout>

    <!-- ===== RIGHT SIDE ===== -->

    <!-- R shoulder, upper-right -->
    <Button
        android:id="@+id/btnR"
        android:layout_width="60dp"
        android:layout_height="40dp"
        android:layout_gravity="top|end"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="44dp"
        android:background="@drawable/btn_pill"
        android:text="R"
        android:textColor="#DDFFFFFF"
        android:textSize="13sp" />

    <!-- Start pill, top -->
    <Button
        android:id="@+id/btnStart"
        android:layout_width="wrap_content"
        android:layout_height="34dp"
        android:layout_gravity="top|end"
        android:layout_marginEnd="90dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/btn_pill"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:text="Start"
        android:textColor="#DDFFFFFF"
        android:textSize="10sp"
        android:textAllCaps="false" />

    <!-- A/B/X/Y diamond, lower-right. Positioned with a nested FrameLayout so
         the four round buttons form the classic diamond. -->
    <FrameLayout
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="20dp">

        <Button
            android:id="@+id/btnX"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="top|center_horizontal"
            android:background="@drawable/btn_round"
            android:text="X"
            android:textColor="#DDFFFFFF"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnB"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="bottom|center_horizontal"
            android:background="@drawable/btn_round"
            android:text="B"
            android:textColor="#DDFFFFFF"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnY"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="center_vertical|start"
            android:background="@drawable/btn_round"
            android:text="Y"
            android:textColor="#DDFFFFFF"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnA"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="center_vertical|end"
            android:background="@drawable/btn_round"
            android:text="A"
            android:textColor="#DDFFFFFF"
            android:textSize="16sp" />
    </FrameLayout>

    <!-- Feature buttons: REC toggles CDL capture, RIP grabs sprites+palette. -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="10dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnLab"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:background="@drawable/btn_pill"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:text="🔬 Lab (código + sprites)"
            android:textColor="#FFD166"
            android:textSize="12sp"
            android:textAllCaps="false" />
    </LinearLayout>

</FrameLayout>
