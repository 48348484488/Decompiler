<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/paletteOffsetInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:hint="offset hex ex 1A0000"
            android:textColorHint="@color/text_secondary"
            android:textColor="@color/text_primary"
            android:fontFamily="monospace"
            android:inputType="textCapCharacters"
            android:maxLines="1" />

        <EditText
            android:id="@+id/paletteCountInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="cores"
            android:text="16"
            android:textColorHint="@color/text_secondary"
            android:textColor="@color/text_primary"
            android:fontFamily="monospace"
            android:inputType="number"
            android:maxLines="1"
            android:layout_marginStart="6dp" />

        <Button
            android:id="@+id/paletteDecodeButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ir"
            android:textAllCaps="false"
            android:backgroundTint="@color/accent"
            android:layout_marginStart="6dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/paletteHintText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Dica: paletas de sprite/BG costumam ter 16 cores (4bpp). Toque numa cor pra ver o valor BGR555."
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingBottom="6dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/paletteRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp" />

</LinearLayout>
