<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Vertical bar of the cross -->
    <item android:left="33%" android:right="33%">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:startColor="#22FFFFFF"
                android:centerColor="#55FFFFFF"
                android:endColor="#22FFFFFF" />
            <corners android:radius="8dp" />
            <stroke android:width="1dp" android:color="#44FFFFFF" />
        </shape>
    </item>
    <!-- Horizontal bar of the cross -->
    <item android:top="33%" android:bottom="33%">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#22FFFFFF"
                android:centerColor="#55FFFFFF"
                android:endColor="#22FFFFFF" />
            <corners android:radius="8dp" />
            <stroke android:width="1dp" android:color="#44FFFFFF" />
        </shape>
    </item>
    <!-- Center hub -->
    <item android:left="38%" android:right="38%" android:top="38%" android:bottom="38%">
        <shape android:shape="oval">
            <solid android:color="#33000000" />
        </shape>
    </item>
</layer-list>
