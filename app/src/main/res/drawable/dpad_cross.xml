<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Vertical bar of the cross (frame is 180dp; 60dp bar centered = 60dp insets L/R) -->
    <item android:left="60dp" android:right="60dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:startColor="#22FFFFFF"
                android:centerColor="#55FFFFFF"
                android:endColor="#22FFFFFF" />
            <corners android:radius="8dp" />
            <stroke android:width="1dp" android:color="#44FFFFFF" />
        </shape>
    </item>
    <!-- Horizontal bar of the cross -->
    <item android:top="60dp" android:bottom="60dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#22FFFFFF"
                android:centerColor="#55FFFFFF"
                android:endColor="#22FFFFFF" />
            <corners android:radius="8dp" />
            <stroke android:width="1dp" android:color="#44FFFFFF" />
        </shape>
    </item>
    <!-- Center hub -->
    <item android:left="68dp" android:right="68dp" android:top="68dp" android:bottom="68dp">
        <shape android:shape="oval">
            <solid android:color="#33000000" />
        </shape>
    </item>
</layer-list>
